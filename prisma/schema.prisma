  bookingId         String    @map("booking_id")
  customerId        String    @map("customer_id")
  unitId            String    @map("unit_id")
  agreementDate     DateTime  @map("agreement_date")
  agreementValue    BigInt    @default(0) @map("agreement_value")
  stampDutyPaid     BigInt    @default(0) @map("stamp_duty_paid")
  documentId        String?   @map("document_id")
  remarks           String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  booking           Booking   @relation(fields: [bookingId], references: [id])

  @@index([organizationId, bookingId])
  @@map("agreement_records")
}

// ─── REGISTRATION RECORDS ────────────────────────────────────────────────────

model RegistrationRecord {
  id                  String    @id @default(uuid())
  organizationId      String    @map("organization_id")
  bookingId           String    @map("booking_id")
  customerId          String    @map("customer_id")
  unitId              String    @map("unit_id")
  registrationDate    DateTime  @map("registration_date")
  registrationNumber  String    @map("registration_number")
  subRegistrar        String?   @map("sub_registrar")
  registrationFee     BigInt    @default(0) @map("registration_fee")
  documentId          String?   @map("document_id")
  remarks             String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  booking             Booking   @relation(fields: [bookingId], references: [id])

  @@index([organizationId, bookingId])
  @@map("registration_records")
}

// ─── APPROVAL REQUESTS ───────────────────────────────────────────────────────

model ApprovalRequest {
  id              String              @id @default(uuid())
  organizationId  String              @map("organization_id")
  requestType     ApprovalRequestType @map("request_type")
  entityType      String              @map("entity_type")
  entityId        String              @map("entity_id")
  requestedBy     String?             @map("requested_by")
  requestData     Json                @default("{}") @map("request_data")
  justification   String?
  status          ApprovalStatus      @default(pending)
  reviewedBy      String?             @map("reviewed_by")
  reviewedAt      DateTime?           @map("reviewed_at")
  reviewRemarks   String?             @map("review_remarks")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, requestType])
  @@map("approval_requests")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id              String      @id @default(uuid())
  organizationId  String      @map("organization_id")
  actorId         String?     @map("actor_id")
  actorRole       String?     @map("actor_role")
  action          AuditAction
  entityType      String      @map("entity_type")
  entityId        String      @map("entity_id")
  entityCode      String?     @map("entity_code")
  beforeState     Json?       @map("before_state")
  afterState      Json?       @map("after_state")
  changes         Json?
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, actorId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
