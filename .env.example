# ============================================
# LeadFlow AI Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ---- SERVER ----
NODE_ENV=development
PORT=5000

# ---- DATABASE (Supabase PostgreSQL) ----
# Get this from: Supabase Dashboard > Project Settings > Database > Connection String > URI
# Make sure to replace [YOUR-PASSWORD] in the URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---- REDIS (Upstash — caching only) ----
# Get these from: Upstash Console > Your Redis Database > REST API section
UPSTASH_REDIS_REST_URL=https://[YOUR-UPSTASH-URL].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR-UPSTASH-TOKEN]

# ---- REDIS (local — BullMQ queues) ----
# BullMQ fires many commands per tick; keep it off Upstash to avoid request limits
# Run locally: redis-server (or Docker: docker run -p 6379:6379 redis:alpine)
BULL_REDIS_URL=redis://localhost:6379

# ---- JWT SECRETS ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use a DIFFERENT random value for each secret — never reuse
JWT_SECRET=[GENERATE-A-64-CHAR-RANDOM-HEX-STRING]
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=[GENERATE-A-DIFFERENT-64-CHAR-RANDOM-HEX-STRING]
JWT_REFRESH_EXPIRES_IN=30d

# ---- PII ENCRYPTION ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This encrypts PAN numbers and Aadhaar numbers at rest
# CRITICAL: Back this up securely. Losing this key = losing all PII data permanently
PII_ENCRYPTION_KEY=[GENERATE-A-64-CHAR-HEX-STRING-EXACTLY-64-CHARS]

# ---- AWS S3 (skip for now — leave as placeholder) ----
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=leadflow-documents

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- APP ----
APP_NAME=LeadFlow AI
API_VERSION=v1
LOG_LEVEL=info
